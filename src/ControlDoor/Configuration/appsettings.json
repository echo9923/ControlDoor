{
  // ============================================================
  // Service —— 服务对外监听与管理鉴权
  // ============================================================
  "Service": {
    // gRPC 监听端口，监听地址固定为 0.0.0.0（所有网卡）；取值范围 1-65535。
    "GrpcListenPort": 5001,
    // 设备管理接口（device.AccessControlService）的 API Key。
    // 为空时不强制鉴权但记录警告；生产环境建议填入随机串。
    "GrpcManagementApiKey": ""
  },

  // ============================================================
  // Database —— SQL Server 连接与启动重试
  // ============================================================
  "Database": {
    // SQL Server 连接字符串，必填；为空时服务启动失败。
    // 建议使用最小权限账号；TrustServerCertificate=True 用于跳过证书校验。
    "ConnectionString": "Server=127.0.0.1;Database=ruoyi-vue-pro;User Id=door_user;Password=change_me;TrustServerCertificate=True;",
    // 单条 SQL 命令的超时（秒）；<=0 时回退默认值 30。
    "CommandTimeoutSeconds": 30,
    // 服务启动时连接数据库失败的重试次数。
    "StartupRetryCount": 10,
    // 启动重试之间的间隔（秒）。
    "StartupRetryIntervalSeconds": 60
  },

  // ============================================================
  // Logging —— 日志目录、保留期与详细程度开关
  // ============================================================
  "Logging": {
    // 日志输出目录，相对路径按服务运行目录解析；不存在时自动创建。
    "LogDirectory": "logs",
    // 日志文件保留天数，超过后自动清理。
    "RetentionDays": 30,
    // 是否记录 gRPC 请求/响应 payload；默认关闭以控制日志体积。
    "EnableGrpcPayloadLogging": false,
    // payload 记录模式：Summary=只记摘要；Full=记录完整 JSON。
    "GrpcPayloadLogMode": "Summary",
    // 仅在 Full 模式生效：是否记录设备密码、API Key 等凭据字段。
    "IncludeCredentialFields": true,
    // 仅在 Full 模式生效：是否记录完整人脸 Base64；默认关闭避免日志膨胀。
    "IncludeFaceImageBase64": false,
    // 是否记录 SDK 调用、错误码和设备任务链路日志（排障建议开启）。
    "EnableSdkTrace": true
  },

  // ============================================================
  // DeviceSdkDispatcher —— 设备固定执行通道（任务队列与 Worker）
  // 所有设备操作都封装成任务，按 device_id 路由到固定 Worker 串行执行；
  // 不同设备可并行，并行度上限 = WorkerCount。
  // ============================================================
  "DeviceSdkDispatcher": {
    // Worker 数量，即跨设备的最大并行度；同一台设备始终在同一 Worker 上串行。<1 时回退 4。
    "WorkerCount": 4,
    // 每个 Worker 的任务队列容量；<100 时回退 1000。
    "QueueCapacity": 1000,
    // 设备任务的默认超时（毫秒）。超时只控制任务等待与结果记录，
    // 对已进入 SDK 的阻塞调用不做强制线程中断。
    "DefaultTaskTimeoutMs": 30000,
    // 是否启用高优先级任务优先排序（登出/门控/布防等优先于普通下发）。
    "HighPriorityQueueEnabled": true
  },

  // ============================================================
  // DeviceConnection —— 设备连接、心跳与掉线重连
  // 重连采用指数退避：ReconnectBaseDelayMs 起步，ReconnectMaxDelayMs 封顶。
  // 重连最大次数借用 DeviceOperationRetry.MaxRetryAttempts。
  // ============================================================
  "DeviceConnection": {
    // 在线状态检测（健康检查）间隔（毫秒）；<5000 时回退 30000。
    "StatusCheckIntervalMs": 30000,
    // 设备登录任务超时（毫秒）。
    "LoginTimeoutMs": 15000,
    // 设备登出任务超时（毫秒）。
    "LogoutTimeoutMs": 10000,
    // 首次重连延迟，也是指数退避的基数（毫秒）。
    "ReconnectBaseDelayMs": 5000,
    // 指数退避的延迟上限（毫秒），5 分钟。
    "ReconnectMaxDelayMs": 300000
  },

  // ============================================================
  // DeviceOperationRetry —— 离线补偿引擎（阶段6）
  // 设备掉线或下发失败时，待办写入 device_operation_retry_states，
  // 后台按指数退避扫描重试，设备恢复后补发。
  // ============================================================
  "DeviceOperationRetry": {
    // 后台扫描到期补偿任务的间隔（秒）。
    "ScanIntervalSeconds": 30,
    // 首次补偿延迟、设备离线推迟延迟，也是指数退避基数（秒）。
    "InitialRetryDelaySeconds": 60,
    // 指数退避的延迟上限（秒），1 小时。
    "MaxRetryDelaySeconds": 3600,
    // 最大补偿尝试次数；达到后写入 exhausted_at 进入终态。
    // 该值同时被用作设备重连的最大次数上限。
    "MaxRetryAttempts": 10,
    // 终态失败记录的保留天数，超过后由清理任务删除。
    "FailureRetentionDays": 7,
    // 每次扫描最多加载/处理的补偿状态条数。
    "BatchSize": 100,
    // 新的补偿意图是否立即到期（下一轮扫描即捞取）。
    "RetryImmediatelyOnNewIntent": true,
    // 终态记录保留天数（备用；清理优先使用 FailureRetentionDays）。
    "TerminalRetentionDays": 7
  },

  // ============================================================
  // FaceEventLogging —— 门禁人脸事件入库与抓拍（阶段7）
  // 设备 ACS 报警上报的进出事件，解析后写入 attendance_gate_v2，
  // 抓拍图片存盘；设备恢复后按 face_event_checkpoint 断点补偿历史事件。
  // ============================================================
  "FaceEventLogging": {
    // 是否启用人脸事件实时入库。
    "Enabled": true,
    // 抓拍图片保存根目录，相对路径按服务运行目录解析；不存在时自动创建。
    "SnapshotRootDirectory": "snapshots",
    // 不做人脸事件入库与补偿的设备 ID 列表（仅影响事件入库，不影响连接/下发）。
    "ExcludedDeviceIds": [],
    // 设备从离线恢复后，是否按断点补偿历史事件。
    "EnableHistoryCompensation": true
  },

  // ============================================================
  // FaceEnrollment —— 人脸录入采集（CaptureFaceStream）
  // ============================================================
  "FaceEnrollment": {
    // 人脸图片大小上限（字节），默认 200KB；超限返回 FACE_TOO_LARGE。
    "MaxFaceImageBytes": 204800,
    // 单次人脸采集任务超时（秒）。
    "CaptureTimeoutSeconds": 60,
    // 采集任务状态在内存中的保留时间（分钟），超期清理。
    "TaskRetentionMinutes": 30
  },

  // ============================================================
  // CameraAlarmDoorInterlock —— 摄像头 AIOP 报警联动门禁常闭（阶段9，预留）
  // 当前默认关闭；配置结构保留，以便后续阶段无需再改配置文件。
  // ============================================================
  "CameraAlarmDoorInterlock": {
    // 是否启用摄像头 AIOP 报警联动门禁常闭（首期默认 false）。
    "Enabled": false,
    // 摄像头到门禁目标的映射列表，每项含：
    //   CameraIpAddress  摄像头 IP（用于匹配报警来源）
    //   DoorDeviceId     联动的门禁设备 ID
    //   DoorNo           门号（默认 1）
    //   CloseSeconds     常闭窗口秒数（默认 5）
    "Mappings": []
  }
}
