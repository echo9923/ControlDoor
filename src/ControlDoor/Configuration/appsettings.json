{
  // ============================================================
  // Service -- service listener and management authentication
  // ============================================================
  "Service": {
    // gRPC listens on 0.0.0.0; valid range is 1-65535.
    "GrpcListenPort": 5001,
    // Leave empty only for local testing. Production should use a random value.
    "GrpcManagementApiKey": ""
  },

  // ============================================================
  // Database -- SQL Server connection and command timeout
  // ============================================================
  "Database": {
    // Placeholder only. Do not commit a real password.
    "ConnectionString": "Server=127.0.0.1;Database=ruoyi-vue-pro;User Id=admin_user;Password=change_me;TrustServerCertificate=True;",
    "CommandTimeoutSeconds": 30
  },

  // ============================================================
  // Logging -- local logs, retention, and slow-operation policy
  // ============================================================
  "Logging": {
    "LogDirectory": "logs",
    "RetentionDays": 30,
    "MinimumLevel": "Info",
    "SlowOperationThresholdMs": 1000
  },

  // ============================================================
  // DeviceRuntime -- fixed worker channels and device task queues
  // ============================================================
  "DeviceRuntime": {
    "WorkerCount": 4,
    "QueueCapacity": 1000,
    "DefaultTaskTimeoutMs": 30000
  },

  // ============================================================
  // HikvisionSdk -- native SDK placement and optional SDK log path
  // ============================================================
  "HikvisionSdk": {
    "Platform": "x64",
    "DllDirectory": "sdk\\Hikvision",
    "SdkLogDirectory": "logs\\sdk",
    "RequireSdkLog": false
  },

  // ============================================================
  // DeviceLifecycle -- login, logout, status check, reconnect
  // ============================================================
  "DeviceLifecycle": {
    "StatusCheckIntervalMs": 30000,
    "LoginTimeoutMs": 15000,
    "LogoutTimeoutMs": 10000,
    "ReconnectBaseDelayMs": 5000,
    "ReconnectMaxDelayMs": 300000,
    "ReArmBaseDelayMs": 1000,
    "ReArmMaxDelayMs": 60000,
    "AlarmStatusProbeEnabled": true,
    "AlarmStatusProbeFailureThreshold": 2
  },

  // ============================================================
  // DeviceOperationRetry -- offline compensation engine
  // ============================================================
  "DeviceOperationRetry": {
    "ScanIntervalSeconds": 30,
    "InitialRetryDelaySeconds": 30,
    "MaxRetryDelaySeconds": 300,
    "MaxRetryAttempts": 4200,
    "FailureRetentionDays": 14,
    "BatchSize": 100,
    "TerminalRetentionDays": 14
  },

  // ============================================================
  // FaceEventLogging -- ACS face event persistence and snapshots
  // ============================================================
  "FaceEventLogging": {
    "Enabled": true,
    "SnapshotRootDirectory": "snapshots",
    "ExcludedDeviceIds": [],
    "ExcludedDeviceIps": [],
    "OfflineCompensationEnabled": true,
    "AlarmDeployType": 0,
    "QueueCapacity": 2000,
    "BatchSize": 50,
    "FlushIntervalMs": 500
  },

  // ============================================================
  // CameraAlarmDoorInterlock -- stage 9 AIOP alarm door interlock
  // Enabled for the current field inventory. A 0x4021 AIOP alarm from a
  // configured camera drives the mapped door to always-close for
  // WindowSeconds, then restores it to normal-controlled state.
  // ============================================================
  "CameraAlarmDoorInterlock": {
    "Enabled": true,
    "WindowSeconds": 5,
    "RestoreRetryIntervalMs": 1000,
    "Mappings": [
      {
        "Camera": { "Id": 25, "Ip": "10.98.26.73" },
        "DoorDevice": { "Id": 19, "Ip": "10.98.26.57" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "检修路 摄像头 1 -> 生产区门禁右出"
      },
      {
        "Camera": { "Id": 25, "Ip": "10.98.26.73" },
        "DoorDevice": { "Id": 20, "Ip": "10.98.26.56" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "检修路 摄像头 1 -> 生产区门禁右进"
      },
      {
        "Camera": { "Id": 25, "Ip": "10.98.26.73" },
        "DoorDevice": { "Id": 21, "Ip": "10.98.26.55" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "检修路 摄像头 1 -> 生产区门禁左出"
      },
      {
        "Camera": { "Id": 25, "Ip": "10.98.26.73" },
        "DoorDevice": { "Id": 22, "Ip": "10.98.26.54" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "检修路 摄像头 1 -> 生产区门禁左进"
      },
      {
        "Camera": { "Id": 26, "Ip": "10.98.26.74" },
        "DoorDevice": { "Id": 15, "Ip": "10.98.26.72" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "平安路 摄像头 2 -> 生产区西门门禁右进"
      },
      {
        "Camera": { "Id": 26, "Ip": "10.98.26.74" },
        "DoorDevice": { "Id": 16, "Ip": "10.98.26.69" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "平安路 摄像头 2 -> 生产区西门门禁右出"
      },
      {
        "Camera": { "Id": 26, "Ip": "10.98.26.74" },
        "DoorDevice": { "Id": 17, "Ip": "10.98.26.71" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "平安路 摄像头 2 -> 生产区西门门禁左出"
      },
      {
        "Camera": { "Id": 26, "Ip": "10.98.26.74" },
        "DoorDevice": { "Id": 18, "Ip": "10.98.26.70" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "平安路 摄像头 2 -> 生产区西门门禁左进"
      },
      {
        "Camera": { "Id": 27, "Ip": "10.98.26.75" },
        "DoorDevice": { "Id": 13, "Ip": "10.98.26.51" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "物资超市 摄像头 3 -> 物资仓库西门门禁出"
      },
      {
        "Camera": { "Id": 27, "Ip": "10.98.26.75" },
        "DoorDevice": { "Id": 14, "Ip": "10.98.26.50" },
        "DoorNos": [1],
        "Enabled": true,
        "Remark": "物资超市 摄像头 3 -> 物资仓库西门门禁进"
      }
    ]
    // Camera and DoorDevice are matched by Ip first; Id is kept for traceability
    // and used only when Ip is empty.
    // DoorNos omitted/empty defaults to [1].
  },

  // ============================================================
  // Devices -- JSON device inventory
  // FilePath is relative to the run directory and is written back
  // when devices are added or deleted through the gRPC API. Items
  // may inline a temporary device list for tests or small deployments;
  // official deployments should keep Items empty and maintain devices.json.
  // ============================================================
  "Devices": {
    "FilePath": "Configuration\\devices.json",
    "BackupOnWrite": true,
    // 可选：指定人脸采集默认设备 ID。填写后 CaptureFaceStream 只用该设备，
    // 离线时严格失败不回退；留空则按 FaceCapture 类型自动选择第一个在线设备。
    "DefaultFaceCaptureDeviceId": 28,
    "Items": []
    // Item shape (Types is a multi-select of Acs / FaceCapture / Camera):
    //   {
    //     "deviceId": 1001,
    //     "name": "1号楼大门门禁",
    //     "types": ["Acs"],
    //     "ipAddress": "192.168.1.64",
    //     "port": 8000,
    //     "username": "admin",
    //     "password": "******",
    //     "enabled": true,
    //     "remark": "东门主通道"
    //   }
    // Mingmou face+ACS devices declare both: ["Acs", "FaceCapture"].
    // IP-camera AIOP devices declare: ["Camera"].
  }
}
