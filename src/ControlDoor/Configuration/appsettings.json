{
  // ============================================================
  // Service -- service listener and management authentication
  // ============================================================
  "Service": {
    // gRPC listens on 0.0.0.0; valid range is 1-65535.
    "GrpcListenPort": 5001,
    // Leave empty only for local testing. Production should use a random value.
    "GrpcManagementApiKey": ""
  },

  // ============================================================
  // Database -- SQL Server connection and command timeout
  // ============================================================
  "Database": {
    // Placeholder only. Do not commit a real password.
    "ConnectionString": "Server=127.0.0.1;Database=ruoyi-vue-pro;User Id=admin_user;Password=change_me;TrustServerCertificate=True;",
    "CommandTimeoutSeconds": 30,
    "StartupRetryCount": 10,
    "StartupRetryIntervalSeconds": 60
  },

  // ============================================================
  // Logging -- local logs and payload recording policy
  // ============================================================
  "Logging": {
    "LogDirectory": "logs",
    "RetentionDays": 30,
    "EnableGrpcPayloadLogging": false,
    "GrpcPayloadLogMode": "Summary",
    "IncludeCredentialFields": true,
    "IncludeFaceImageBase64": false,
    "EnableSdkTrace": true
  },

  // ============================================================
  // DeviceRuntime -- fixed worker channels and device task queues
  // ============================================================
  "DeviceRuntime": {
    "WorkerCount": 4,
    "QueueCapacity": 1000,
    "DefaultTaskTimeoutMs": 30000,
    "HighPriorityQueueEnabled": true
  },

  // ============================================================
  // HikvisionSdk -- native SDK placement and optional SDK log path
  // ============================================================
  "HikvisionSdk": {
    "Platform": "x64",
    "DllDirectory": "sdk\\Hikvision",
    "EnableSdkLog": true,
    "SdkLogDirectory": "logs\\sdk",
    "RequireSdkLog": false,
    "ValidateNativeInit": false
  },

  // ============================================================
  // DeviceLifecycle -- login, logout, status check, reconnect
  // ============================================================
  "DeviceLifecycle": {
    "StatusCheckIntervalMs": 30000,
    "LoginTimeoutMs": 15000,
    "LogoutTimeoutMs": 10000,
    "ReconnectBaseDelayMs": 5000,
    "ReconnectMaxDelayMs": 300000,
    "ReArmBaseDelayMs": 1000,
    "ReArmMaxDelayMs": 60000,
    "AlarmStatusProbeEnabled": true,
    "AlarmStatusProbeFailureThreshold": 2
  },

  // ============================================================
  // DeviceOperationRetry -- offline compensation engine
  // ============================================================
  "DeviceOperationRetry": {
    "ScanIntervalSeconds": 30,
    "InitialRetryDelaySeconds": 60,
    "MaxRetryDelaySeconds": 3600,
    "MaxRetryAttempts": 10,
    "FailureRetentionDays": 7,
    "BatchSize": 100,
    "RetryImmediatelyOnNewIntent": true,
    "TerminalRetentionDays": 7
  },

  // ============================================================
  // FaceEventLogging -- ACS face event persistence and snapshots
  // ============================================================
  "FaceEventLogging": {
    "Enabled": true,
    "SnapshotRootDirectory": "snapshots",
    "ExcludedDeviceIds": [],
    "ExcludedDeviceIps": [],
    "OfflineCompensationEnabled": true,
    "AlarmDeployType": 0,
    "QueueCapacity": 2000,
    "EnableHistoryCompensation": false,
    "BatchSize": 50,
    "FlushIntervalMs": 500
  },

  // ============================================================
  // FaceEnrollment -- face image upload and capture task limits
  // ============================================================
  "FaceEnrollment": {
    "MaxFaceImageBytes": 204800,
    "CaptureTimeoutSeconds": 60,
    "TaskRetentionMinutes": 30
  },

  // ============================================================
  // CameraAlarmDoorInterlock -- stage 9 AIOP alarm door interlock
  // Disabled by default. When enabled, a 0x4021 AIOP alarm from a
  // configured camera drives the mapped door to always-close for
  // WindowSeconds, then restores it to normal-controlled state.
  // ============================================================
  "CameraAlarmDoorInterlock": {
    "Enabled": false,
    "WindowSeconds": 5,
    "DoorControlSdkLockTimeoutMs": 5000,
    "RestoreRetryIntervalMs": 1000,
    "Mappings": []
    // Mapping shape (Enabled=true to activate a mapping):
    //   {
    //     "Camera":    { "Ip": "10.0.0.1", "Id": 0 },
    //     "DoorDevice": { "Ip": "10.0.0.2", "Id": 0 },
    //     "DoorNos": [1],
    //     "Enabled": true,
    //     "Remark": "东门摄像头联动东门门禁"
    //   }
    // Camera and DoorDevice use Ip first, falling back to Id when Ip is empty.
    // DoorNos omitted/empty defaults to [1].
  },

  // ============================================================
  // Devices -- JSON device inventory
  // FilePath is relative to the run directory and is written back
  // when devices are added or deleted through the gRPC API. Items
  // may inline a temporary device list for tests or small deployments;
  // official deployments should keep Items empty and maintain devices.json.
  // ============================================================
  "Devices": {
    "FilePath": "Configuration\\devices.json",
    "BackupOnWrite": true,
    "Items": []
    // Item shape (Types is a multi-select of Acs / FaceCapture / Camera):
    //   {
    //     "deviceId": 1001,
    //     "name": "1号楼大门门禁",
    //     "types": ["Acs"],
    //     "ipAddress": "192.168.1.64",
    //     "port": 8000,
    //     "username": "admin",
    //     "password": "******",
    //     "enabled": true,
    //     "remark": "东门主通道"
    //   }
    // Mingmou face+ACS devices declare both: ["Acs", "FaceCapture"].
    // IP-camera AIOP devices declare: ["Camera"].
  }
}
