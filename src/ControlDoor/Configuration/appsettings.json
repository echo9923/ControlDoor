{
  // ============================================================
  // Service -- service listener and management authentication
  // ============================================================
  "Service": {
    // gRPC listens on 0.0.0.0; valid range is 1-65535.
    "GrpcListenPort": 5001,
    // Leave empty only for local testing. Production should use a random value.
    "GrpcManagementApiKey": ""
  },

  // ============================================================
  // Database -- SQL Server connection and command timeout
  // ============================================================
  "Database": {
    // Placeholder only. Do not commit a real password.
    "ConnectionString": "Server=127.0.0.1;Database=ruoyi-vue-pro;User Id=door_user;Password=change_me;TrustServerCertificate=True;",
    "CommandTimeoutSeconds": 30,
    "StartupRetryCount": 10,
    "StartupRetryIntervalSeconds": 60
  },

  // ============================================================
  // Logging -- local logs and payload recording policy
  // ============================================================
  "Logging": {
    "LogDirectory": "logs",
    "RetentionDays": 30,
    "EnableGrpcPayloadLogging": false,
    "GrpcPayloadLogMode": "Summary",
    "IncludeCredentialFields": true,
    "IncludeFaceImageBase64": false,
    "EnableSdkTrace": true
  },

  // ============================================================
  // DeviceRuntime -- fixed worker channels and device task queues
  // ============================================================
  "DeviceRuntime": {
    "WorkerCount": 4,
    "QueueCapacity": 1000,
    "DefaultTaskTimeoutMs": 30000,
    "HighPriorityQueueEnabled": true
  },

  // ============================================================
  // HikvisionSdk -- native SDK placement and optional SDK log path
  // ============================================================
  "HikvisionSdk": {
    "Platform": "x64",
    "DllDirectory": "sdk\\Hikvision",
    "EnableSdkLog": true,
    "SdkLogDirectory": "logs\\sdk",
    "RequireSdkLog": false,
    "ValidateNativeInit": false
  },

  // ============================================================
  // DeviceLifecycle -- login, logout, status check, reconnect
  // ============================================================
  "DeviceLifecycle": {
    "StatusCheckIntervalMs": 30000,
    "LoginTimeoutMs": 15000,
    "LogoutTimeoutMs": 10000,
    "ReconnectBaseDelayMs": 5000,
    "ReconnectMaxDelayMs": 300000
  },

  // ============================================================
  // DeviceOperationRetry -- offline compensation engine
  // ============================================================
  "DeviceOperationRetry": {
    "ScanIntervalSeconds": 30,
    "InitialRetryDelaySeconds": 60,
    "MaxRetryDelaySeconds": 3600,
    "MaxRetryAttempts": 10,
    "FailureRetentionDays": 7,
    "BatchSize": 100,
    "RetryImmediatelyOnNewIntent": true,
    "TerminalRetentionDays": 7
  },

  // ============================================================
  // FaceEventLogging -- ACS face event persistence and snapshots
  // ============================================================
  "FaceEventLogging": {
    "Enabled": true,
    "SnapshotRootDirectory": "snapshots",
    "ExcludedDeviceIds": [],
    "ExcludedDeviceIps": [],
    "OfflineCompensationEnabled": true,
    "AlarmDeployType": 0,
    "QueueCapacity": 2000,
    "EnableHistoryCompensation": false
  },

  // ============================================================
  // FaceEnrollment -- face image upload and capture task limits
  // ============================================================
  "FaceEnrollment": {
    "MaxFaceImageBytes": 204800,
    "CaptureTimeoutSeconds": 60,
    "TaskRetentionMinutes": 30
  },

  // ============================================================
  // CameraAlarmDoorInterlock -- reserved for later AIOP linkage
  // ============================================================
  "CameraAlarmDoorInterlock": {
    "Enabled": false,
    "Mappings": []
  }
}
