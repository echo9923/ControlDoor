{
  // ============================================================
  // 现场部署配置模板（appsettings.deploy.json）
  // ------------------------------------------------------------
  // 本文件与 appsettings.json 仅在数据库连接串上有差异：
  //   - appsettings.json 使用 change_me 占位密码（脱敏，进仓库）
  //   - 本文件使用 stage1_4_integration_seed.sql 建立的 admin_user 真实账号
  //
  // 现场部署步骤：
  //   1. 将本文件复制为 appsettings.json（覆盖运行目录下的同名文件）
  //      运行目录为：{安装目录}\Configuration\appsettings.json
  //   2. 根据现场环境修改 Server（SQL Server 实例地址）和 gRPC 端口
  //   3. 执行 ControlDoor.exe --validate-config 校验通过后再装服务
  //
  // 安全提醒：本文件含真实账号密码，不要提交真实环境改后的副本回仓库。
  //           如生产账号密码与脚本默认值不同，请在现场修改后自行保管。
  // ============================================================

  // ============================================================
  // Service -- service listener and management authentication
  // ============================================================
  "Service": {
    // gRPC listens on 0.0.0.0; valid range is 1-65535.
    "GrpcListenPort": 5001,
    // Leave empty only for local testing. Production should use a random value.
    "GrpcManagementApiKey": ""
  },
  // ============================================================
  // Database -- SQL Server connection and command timeout
  // ============================================================
  "Database": {
    // 现场账号：stage1_4_integration_seed.sql 建立的 admin_user，初始密码 123456。
    // 若现场已改密码，请同步修改下方 Password 值。
    "ConnectionString": "Server=127.0.0.1;Database=ruoyi-vue-pro;User Id=admin_user;Password=123456;TrustServerCertificate=True;",
    "CommandTimeoutSeconds": 30
  },
  // ============================================================
  // Logging -- local logs, retention, and slow-operation policy
  // ============================================================
  "Logging": {
    "LogDirectory": "logs",
    "RetentionDays": 30,
    "MinimumLevel": "Info",
    "SlowOperationThresholdMs": 1000
  },
  // ============================================================
  // DeviceRuntime -- fixed worker channels and device task queues
  // ============================================================
  "DeviceRuntime": {
    "WorkerCount": 4,
    "QueueCapacity": 1000,
    "DefaultTaskTimeoutMs": 30000
  },
  // ============================================================
  // HikvisionSdk -- native SDK placement and optional SDK log path
  // ============================================================
  "HikvisionSdk": {
    "Platform": "x64",
    "DllDirectory": "sdk\\Hikvision",
    "SdkLogDirectory": "logs\\sdk",
    "RequireSdkLog": false
  },
  // ============================================================
  // DeviceLifecycle -- login, logout, status check, reconnect
  // ============================================================
  "DeviceLifecycle": {
    "StatusCheckIntervalMs": 30000,
    "LoginTimeoutMs": 15000,
    "LogoutTimeoutMs": 10000,
    "ReconnectBaseDelayMs": 5000,
    "ReconnectMaxDelayMs": 300000,
    "ReArmBaseDelayMs": 1000,
    "ReArmMaxDelayMs": 60000,
    "AlarmStatusProbeEnabled": true,
    "AlarmStatusProbeFailureThreshold": 2
  },
  // ============================================================
  // DeviceOperationRetry -- offline compensation engine
  // ============================================================
  "DeviceOperationRetry": {
    "ScanIntervalSeconds": 30,
    "InitialRetryDelaySeconds": 30,
    "MaxRetryDelaySeconds": 300,
    "MaxRetryAttempts": 4200,
    "FailureRetentionDays": 14,
    "BatchSize": 100,
    "TerminalRetentionDays": 14
  },
  // ============================================================
  // FaceEventLogging -- ACS face event persistence and snapshots
  // ============================================================
  "FaceEventLogging": {
    "Enabled": true,
    "SnapshotRootDirectory": "snapshots",
    "ExcludedDeviceIds": [],
    "ExcludedDeviceIps": [],
    "OfflineCompensationEnabled": true,
    "AlarmDeployType": 0,
    "QueueCapacity": 2000,
    "BatchSize": 50,
    "FlushIntervalMs": 500
  },
  // ============================================================
  // CameraAlarmDoorInterlock -- stage 9 AIOP alarm door interlock
  // Enabled for the current field inventory. A 0x4021 AIOP alarm from a
  // configured camera drives the mapped door to always-close for
  // WindowSeconds, then restores it to normal-controlled state.
  // ============================================================
  "CameraAlarmDoorInterlock": {
    "Enabled": true,
    "WindowSeconds": 5,
